datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Card {
  id            String   @id @default(uuid())
  scryfallId    String   @unique
  name          String
  typeLine      String
  colorIdentity String[]
  cmc           Float
  imageNormal   String?
  imageArtCrop  String?
  colors        String[]
  setCode       String
  setName       String
  isBasicLand   Boolean?

  deckCards DeckCard[]

  commanderDeck Deck? @relation("DeckCommander")

  set Set @relation(fields: [setCode], references: [name])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index(setCode)
}

model Set {
  id        String    @id @default(uuid())
  name      String    @unique
  releaseAt DateTime?
  cards     Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deck {
  id        String     @id @default(uuid())
  name      String
  format    String
  deckCards DeckCard[]

  commanderId String? @unique // FK opcional
  commander   Card?   @relation("DeckCommander", fields: [commanderId], references: [id]) // lado dono

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeckCard {
  id String @id @default(uuid())

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id])

  cardId String
  card   Card   @relation(fields: [cardId], references: [id])

  quantity Int

  @@unique([deckId, cardId])
  @@index([deckId])
  @@index([cardId])
}
