datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  decks Deck[]
}

model Card {
  id           String   @id @default(uuid())
  scryfallId   String   @unique
  name         String
  typeLine     String
  cmc          Float
  imageNormal  String?
  imageArtCrop String?
  setCode      String
  setName      String
  isBasicLand  Boolean?

  deckCards DeckCard[]

  commanderDeck Deck? @relation("DeckCommander")

  set Set @relation(fields: [setCode], references: [name])

  // Relacionamentos para listas
  colorIdentities CardColorIdentity[]
  colors          CardColor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index(setCode)
}

model CardColorIdentity {
  id     Int    @id @default(autoincrement())
  cardId String
  value  String

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId])
}

model CardColor {
  id     Int    @id @default(autoincrement())
  cardId String
  value  String

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId])
}

model Set {
  id        String    @id @default(uuid())
  name      String    @unique
  releaseAt DateTime?
  cards     Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deck {
  id        String     @id @default(uuid())
  name      String
  format    String
  deckCards DeckCard[]

  commanderId String? @unique // FK opcional
  commander   Card?   @relation("DeckCommander", fields: [commanderId], references: [id]) // lado dono

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeckCard {
  id String @id @default(uuid())

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id])

  cardId String
  card   Card   @relation(fields: [cardId], references: [id])

  quantity Int

  @@unique([deckId, cardId])
  @@index([deckId])
  @@index([cardId])
}
