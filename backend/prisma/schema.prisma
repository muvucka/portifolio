model Card {
  id String @id @default(uuid())
  name String
  imageUrl String?
  setId String
  set Set @relation(fields: [setId], references: [id])

  deckCards DeckCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([setId])
}

model Set {
  id String @id @default(uuid())
  name String @unique
  releaseAt DateTime?
  cards Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deck {
  id String @id @default(uuid())
  name String
  deckCards DeckCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeckCard {
  id String @id @default(uuid())

  deckId String
  deck Deck @relation(fields: [deckId], references: [id])

  cardId String
  card Card @relation(fields: [cardId], references: [id])

  amount Int

  @@unique([deckId, cardId])
  @@index([deckId])
  @@index([cardId])
}