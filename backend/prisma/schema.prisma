datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decks         Deck[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Card {
  id              String   @id @default(uuid())
  scryfallId      String   @unique
  name            String
  typeLine        String
  cmc             Float
  imageNormal     String?
  imageArtCrop    String?
  setCode         String
  setName         String
  isBasicLand     Boolean?
  collectorNumber String? // Adicionando o campo collector_number

  deckCards DeckCard[]

  commanderDeck Deck? @relation("DeckCommander")

  set Set @relation(fields: [setCode], references: [code])

  // Relacionamentos para listas
  colorIdentities CardColorIdentity[]
  colors          CardColor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Índice composto para busca única por nome e código de set
  @@unique([name, setCode])
  @@index([name])
  @@index(setCode)
}

model CardColorIdentity {
  id     Int    @id @default(autoincrement())
  cardId String
  value  String

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId])
}

model CardColor {
  id     Int    @id @default(autoincrement())
  cardId String
  value  String

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId])
}

model Set {
  id        String    @id @default(uuid())
  code      String    @unique // 👈 ESSENCIAL (ex: "cmm")
  name      String
  type      String // commander, expansion, etc
  iconSvg   String? // 👈 imagem do set
  releaseAt DateTime?

  cards Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([releaseAt])
  @@index([type])
  @@map("`Set`") 
}

enum DeckSection {
  meus
  proximos
}

model Deck {
  id        String      @id @default(uuid())
  name      String
  format    String
  section   DeckSection @default(meus)
  deckCards DeckCard[]

  commanderId String? @unique // FK opcional
  commander   Card?   @relation("DeckCommander", fields: [commanderId], references: [id]) // lado dono

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeckCard {
  id String @id @default(uuid())

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id])

  cardId String
  card   Card   @relation(fields: [cardId], references: [id])

  quantity Int

  @@unique([deckId, cardId])
  @@index([deckId])
  @@index([cardId])
}
