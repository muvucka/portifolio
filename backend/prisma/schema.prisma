model Card {
  id String @id @default(uuid())
  scryfallId String @unique
  name String
  typeLine String
  cmc String
  imageNormal String?
  imageArtCrop String?
  colors String[]
  setCode String
  setName String

  deckCards DeckCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index(setCode)
}

model Set {
  id String @id @default(uuid())
  name String @unique
  releaseAt DateTime?
  cards Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deck {
  id String @id @default(uuid())
  name String
  format String
  deckCards DeckCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeckCard {
  id String @id @default(uuid())

  deckId String
  deck Deck @relation(fields: [deckId], references: [id])

  cardId String
  card Card @relation(fields: [cardId], references: [id])

  quantity Int

  @@unique([deckId, cardId])
  @@index([deckId])
  @@index([cardId])
}